{
  "name": "PHCI Plant Signal Classifier",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  // System packages needed before pip install
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  // Run after container is created — installs all Python dependencies
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt",

  // Forward port 8888 for JupyterLab if needed
  "forwardPorts": [8888, 1883],
  // 8888 = Jupyter  |  1883 = MQTT broker (if running locally)

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-toolsai.jupyter",
        "ms-python.pylint",
        "redhat.vscode-yaml",
        "ms-vscode.serial-monitor"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "editor.formatOnSave": true,
        "[python]": { "editor.defaultFormatter": "ms-python.black-formatter" }
      }
    }
  },

  // Environment variables available inside the container
  "remoteEnv": {
    "PYTHONPATH": "/workspaces/plant-signal-classifier/src",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "MPLBACKEND": "Agg",
    // MPLBACKEND=Agg is REQUIRED — Codespaces has no display server.
    // Without this matplotlib.pyplot.show() crashes the process.
    "PHCI_ENV": "codespaces"
  },

  // Mount host USB devices when using GitHub Codespaces on a local machine
  // Requires usbipd-win on Windows host or usbip on Linux host
  // See Section 8 for hardware connection instructions
  "mounts": []
}
